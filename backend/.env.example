# ForkFox Backend — Environment Config
# Copy to .env and fill in real values. Never commit .env.

# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-hex-string
APP_DEBUG=false

# Auth (JWT)
JWT_SECRET=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./forkfox.db

# Redis (optional — falls back to in-memory limiter if not set)
REDIS_URL=redis://localhost:6379/0

# Rate limits (requests per window)
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SCORING=30/minute
RATE_LIMIT_AUTH=10/minute

# AI scoring (placeholder — fill when AI key obtained)
OPENAI_API_KEY=
SCORING_MODEL=gpt-4o-mini

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://forkfox.ai
