      "version": 1,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 9,
      "containerId": null,
      "originalText": "THE GREAT DEBATE · WHIZ vs PROVOLONE vs AMERICAN",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mntc3ah1r4ryguwd91a",
      "type": "text",
      "x": 3215,
      "y": 2812,
      "strokeColor": "#d4d4d8",
      "text": "Whiz = the tourist trap answer. Provolone = the local move. American = the dad choice.",
      "fontSize": 11,
      "angle": 0,
      "fillStyle": "hachure",
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "backgroundColor": "transparent",
