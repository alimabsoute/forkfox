      "type": "text",
      "x": 3215,
      "y": 2735,
      "strokeColor": "#d4d4d8",
      "text": "Pat Olivieri, 1930, a hot dog stand at 9th and Passyunk. He ran out of hot dogs and grilled",
      "fontSize": 11,
      "angle": 0,
      "fillStyle": "hachure",
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "backgroundColor": "transparent",
