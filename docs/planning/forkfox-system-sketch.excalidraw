      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "seed": 742987,
      "isDeleted": false,
      "locked": false,
      "link": null,
      "updated": 1,
      "versionNonce": 518383646,
      "version": 1,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 8,
      "containerId": null,
      "originalText": "Pat Olivieri, 1930, a hot dog stand at 9th and Passyunk. He ran out of hot dogs and grilled",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mntc37q3llw7abh00np",
      "type": "text",
      "x": 3215,
      "y": 2753,
      "strokeColor": "#d4d4d8",
      "text": "beef scraps instead. A cab driver smelled it, asked for one. The cheese came 15 years later.",
