      "height": 13.75,
      "groupIds": [],
      "frameId": null,
      "boundElements": null,
      "seed": 1002953997,
      "isDeleted": false,
      "locked": false,
      "link": null,
      "updated": 1,
      "versionNonce": 1412358104,
      "version": 1,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 8,
      "containerId": null,
      "originalText": "Whiz = the tourist trap answer. Provolone = the local move. American = the dad choice.",
      "autoResize": true,
      "lineHeight": 1.25
    },
